# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# production
/build

# env (NEVER commit secrets — Turso token, GitHub token, auth secret)
.env
.env.local
.env*.local
.env.production

# misc
.DS_Store
*.pem
.vscode/
.idea/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# vercel
.vercel

# local dev database (libSQL/SQLite file used when no hosted Turso creds)
local.db
*.db
*.db-journal
*.db-wal
*.db-shm

# uploads (admin logo + attachments)
/public/uploads/*
!/public/uploads/.gitkeep
