# Kadam Production — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# Turso (libSQL) database
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Auth — generate a long random string of 32+ chars (e.g. `openssl rand -base64 32`)
AUTH_SECRET=replace-with-at-least-32-random-characters-here

# Optional: one-time setup bootstrap bearer token for /api/setup
# SETUP_BOOTSTRAP_TOKEN=

# Optional Turnstile / external CAPTCHA can be added later; built-in math CAPTCHA
# is enforced automatically after repeated auth failures.

# App
NEXT_PUBLIC_APP_NAME=Kadam Production
NEXT_PUBLIC_APP_TAGLINE=Professional Event Services

# Logo upload storage (local file write into /public/uploads — already gitignored)
# On Vercel, switch to a real bucket if needed.
